# Public URL where this app is hosted.
APP_URL="https://wapi-saas.onrender.com"

# Frontend API base URL. Use the Render URL when building a static frontend elsewhere.
VITE_API_URL="https://wapi-saas.onrender.com"

# Comma-separated browser origins that can call the API.
# Vercel preview/production domains are also allowed by the server CORS guard.
ALLOWED_ORIGINS="https://wapi-saas.onrender.com,http://localhost:3000,http://localhost:3100"

# Razorpay test/live credentials. Keep real values in .env or deployment secrets.
RAZORPAY_KEY_ID="YOUR_RAZORPAY_KEY_ID"
RAZORPAY_KEY_SECRET="YOUR_RAZORPAY_KEY_SECRET"
